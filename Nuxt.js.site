<script setup>
// Teks lesen
const mplText = `Mozilla Public License Version 3.0 (modified)
==================================

1. Definitions
...
... (sila rujuk teks penuh dari versi HTML sebelumnya)
`;

const mitText = `MIT License (Expat)

Copyright (c) 2026 Muhamad Sazwan Bin Ismail (Sazwanismail)

Permission is hereby granted, free of charge, to any person obtaining a copy
... (teks penuh MIT)
`;

// Data pengguna dari API
const { data: users, pending, refresh } = useFetch('/api/users')

const newUser = reactive({ name: '', email: '' })

async function addUser() {
  await $fetch('/api/users', {
    method: 'POST',
    body: newUser
  })
  newUser.name = ''
  newUser.email = ''
  refresh()
}

// Fungsi salin teks (client-side)
onMounted(() => {
  document.querySelectorAll('.btn-copy').forEach(btn => {
    btn.addEventListener('click', function() {
      const targetId = this.getAttribute('data-target')
      const targetEl = document.getElementById(targetId)
      if (targetEl) {
        navigator.clipboard.writeText(targetEl.innerText).then(() => {
          const original = this.innerText
          this.innerText = '✓ Disalin!'
          setTimeout(() => this.innerText = original, 1500)
        })
      }
    })
  })
})
</script>

